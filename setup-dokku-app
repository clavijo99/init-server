#!/bin/bash

echo "===== SETUP DOKKU APP PRO 🚀 ====="

# validar root
if [ "$EUID" -ne 0 ]; then
  echo "❌ Usa: sudo ./setup-dokku-app.sh"
  exit 1
fi

read -p "Nombre de la app: " APP_NAME

if [ -z "$APP_NAME" ]; then
  echo "❌ Debes ingresar el nombre de la app"
  exit 1
fi

APP_PATH="/home/dokku/$APP_NAME"
NGINX_DIR="$APP_PATH/nginx.conf.d"

mkdir -p $NGINX_DIR

echo "===== DETECTANDO RUTA DEL PROYECTO ====="

# detectar si existe /app o /src dentro del contenedor
APP_DIR=$(dokku enter $APP_NAME web bash -c "if [ -d /app ]; then echo /app; elif [ -d /src ]; then echo /src; else echo /app; fi")

echo "✔ Ruta detectada: $APP_DIR"

STATIC_CONTAINER="$APP_DIR/static"
MEDIA_CONTAINER="$APP_DIR/media"

echo "===== LIMPIANDO CONFIGS VIEJAS ====="

rm -rf $NGINX_DIR/*
mkdir -p $NGINX_DIR
chown -R dokku:dokku $NGINX_DIR

echo "===== STORAGE ====="

read -p "¿Usar storage persistente? (y/n): " USE_STORAGE

if [[ "$USE_STORAGE" == "y" ]]; then
  BASE_PATH="/var/lib/dokku/data/storage/$APP_NAME"

  mkdir -p $BASE_PATH/static
  mkdir -p $BASE_PATH/media

  chown -R dokku:dokku $BASE_PATH
  chmod -R 755 $BASE_PATH

  dokku storage:ensure-directory $APP_NAME

  dokku storage:unmount $APP_NAME $STATIC_CONTAINER 2>/dev/null
  dokku storage:unmount $APP_NAME $MEDIA_CONTAINER 2>/dev/null

  dokku storage:mount $APP_NAME $BASE_PATH/static:$STATIC_CONTAINER
  dokku storage:mount $APP_NAME $BASE_PATH/media:$MEDIA_CONTAINER

  STATIC_PATH="$BASE_PATH/static"
  MEDIA_PATH="$BASE_PATH/media"

  echo "✔ Storage montado correctamente"

else
  echo "✔ Sin storage persistente"
fi

echo "===== DJANGO ====="

read -p "¿Es una app Django? (y/n): " IS_DJANGO

if [[ "$IS_DJANGO" == "y" ]]; then

  NGINX_SERVE="$NGINX_DIR/serve-files.conf"

  cat <<EOF > $NGINX_SERVE
location /static/ {
  alias $STATIC_PATH/;
  expires 30d;
  add_header Cache-Control "public";
}

location /media/ {
  alias $MEDIA_PATH/;
  expires 30d;
  add_header Cache-Control "public";
}
EOF

  chown dokku:dokku $NGINX_SERVE

  echo ""
  echo "👉 AGREGA ESTO EN settings.py:"
  echo ""
  echo "STATIC_URL = '/static/'"
  echo "STATIC_ROOT = '$STATIC_CONTAINER'"
  echo ""
  echo "MEDIA_URL = '/media/'"
  echo "MEDIA_ROOT = '$MEDIA_CONTAINER'"
fi

echo "===== CORS ====="

read -p "¿Habilitar CORS abierto? (y/n): " ENABLE_CORS

if [[ "$ENABLE_CORS" == "y" ]]; then
  cat <<EOF > $NGINX_DIR/cors.conf
add_header "Access-Control-Allow-Origin" * always;
add_header "Access-Control-Allow-Methods" "GET, POST, PUT, OPTIONS, HEAD, PATCH, DELETE" always;
add_header "Access-Control-Allow-Headers" "Authorization, Origin, X-Requested-With, Content-Type, Accept" always;

if (\$request_method = OPTIONS) {
  return 204;
}
EOF

  chown dokku:dokku $NGINX_DIR/cors.conf
fi

echo "===== FILE SIZE ====="

read -p "Tamaño máximo upload (default 20M): " FILE_SIZE
FILE_SIZE=${FILE_SIZE:-20M}

dokku nginx:set $APP_NAME client-max-body-size $FILE_SIZE

echo "===== HSTS ====="

read -p "¿Habilitar HSTS? (solo si usas SSL) (y/n): " ENABLE_HSTS

if [[ "$ENABLE_HSTS" == "y" ]]; then
  cat <<EOF > $NGINX_DIR/hsts.conf
add_header Strict-Transport-Security "max-age=15724800; includeSubdomains" always;
EOF

  chown dokku:dokku $NGINX_DIR/hsts.conf
fi

echo "===== RELOAD NGINX ====="

dokku nginx:reload $APP_NAME

echo "===== RESTART APP ====="

dokku ps:restart $APP_NAME

echo "===== LISTO 🚀 ====="

if [[ "$IS_DJANGO" == "y" ]]; then
  echo ""
  echo "👉 Ejecuta ahora:"
  echo "dokku run $APP_NAME python manage.py collectstatic --noinput"
fi
